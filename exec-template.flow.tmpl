form:
  - key: ProjectName
    prompt: What is your project name?
  - key: Port
    prompt: Default port for your app?
    default: "8080"
template: |
  namespace: {{ lower(form["ProjectName"]) }}
  executables:
    - verb: start
      name: dev
      description: Start {{ form["ProjectName"] }} in development mode.
      exec:
        params:
          - envKey: PORT
            text: '{{ form["Port"] }}'
        cmd: |
          echo "Starting {{ form["ProjectName"] }} on port ${PORT}..."
          # Replace with your project's actual start command

    - verb: check
      name: env
      description: Verify required environment variables are set.
      exec:
        cmd: |
          echo "Checking environment for {{ form["ProjectName"] }}..."
          [ -f .env ] && echo ".env found" || echo "Warning: .env not found"
          env | grep -i "{{ lower(form["ProjectName"]) }}" | sort || true
